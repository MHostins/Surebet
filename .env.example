# Obrigatorio para Betfair Brasil via certlogin
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
BETFAIR_CERT_FILE=C:\Projetos\API-Betfair\certs\client.crt
BETFAIR_KEY_FILE=C:\Projetos\API-Betfair\certs\client.key

# Alternativa legada: use em vez de BETFAIR_CERT_FILE/BETFAIR_KEY_FILE.
# BETFAIR_CERT_PATH=C:\caminho\client.crt,C:\caminho\client.key
BETFAIR_CERT_PATH=

# Endpoints Betfair Brasil validados no projeto C:\Projetos\API-Betfair
BETFAIR_API_BASE_URL=https://api.betfair.bet.br/exchange/betting/rest/v1.0
BETFAIR_CERT_LOGIN_URL=https://identitysso-cert.betfair.bet.br/api/certlogin
BETFAIR_COMMISSION=0.05

# Obrigatorio para Matchbook global
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=
MATCHBOOK_API_BASE_URL=https://api.matchbook.com
MATCHBOOK_COMMISSION=0.02
MATCHBOOK_BR_COMMISSION=0.02

# Experimental read-only para Matchbook Brasil regional.
# Nao cole cookies reais em codigo. Use apenas no .env local, se necessario.
MATCHBOOK_BR_API_BASE_URL=https://mexchange-api.matchbook.bet.br
MATCHBOOK_BR_COOKIE=

# Simulacao e diagnostico
STAKE_TOTAL=100
MIN_ARBITRAGE_MARGIN=0.01
MAX_START_TIME_DELTA_MINUTES=90
MIN_EVENT_MATCH_CONFIDENCE=0.85
MIN_ODDS_DIFFERENCE_PERCENT=5
MIN_LIQUIDITY_BETFAIR=50
MIN_LIQUIDITY_MATCHBOOK_BR=50
TEAM_ALIASES_PATH=config/team_aliases.json
REQUEST_TIMEOUT=20
OUTPUT_DIR=outputs

# The Odds API (Agregador)
THE_ODDS_API_KEY=your_odds_api_key_here
THE_ODDS_API_REGIONS=eu
THE_ODDS_API_BOOKMAKERS=pinnacle,betano,sportingbet,novibet,bet365
THE_ODDS_API_SPORTS=mma_mixed_martial_arts,baseball_mlb,basketball_wnba,soccer_brazil_serie_b,soccer_fifa_world_cup,tennis_atp_halle_open,tennis_atp_queens_club_champ,tennis_wta_german_open
ODDS_HISTORY_DB_PATH=outputs/odds_history.db
WATCH_MULTI_BOOKMAKER_INTERVAL_SECONDS=300
WATCH_MULTI_BOOKMAKER_MAX_CYCLES=0
WATCH_MONEYLINE_INTERVAL_SECONDS=300
WATCH_MONEYLINE_MAX_CYCLES=0
WATCH_INTERVAL_SECONDS=300
WATCH_MAX_CYCLES=0

# Novibet read-only public inspection via Playwright.
# Nao usa login, nao salva cookies e nao interage com cupom/apostas.
NOVIBET_PUBLIC_URL=https://www.novibet.bet.br/apostas-esportivas
NOVIBET_HEADLESS=true
NOVIBET_NAVIGATION_TIMEOUT_MS=30000
NOVIBET_POST_LOAD_WAIT_MS=3000

# Opportunity alerts read-only
ALERT_NEAR_MISS_DISTANCE_PERCENT=2.0

# SureBet.com bookmaker discovery research read-only.
# Usa login apenas para leitura da pagina autenticada; nao salva cookies nem executa apostas.
SUREBET_USERNAME=
SUREBET_PASSWORD=
SUREBET_BASE_URL=https://pt.surebet.com
SUREBET_DISCOVERY_POLL_SECONDS=5
SUREBET_DISCOVERY_MAX_CYCLES=0
SUREBET_DISCOVERY_HEADLESS=false
SUREBET_DISCOVERY_OUTPUT_DIR=outputs/bookmaker_discovery
SUREBET_DISCOVERY_MIN_PROFIT_CHANGE=0.05
SUREBET_DISCOVERY_ODDS_CHANGE_EPSILON=0.01




